import /init.recovery.microtrust.rc

on init
    setprop sys.usb.configfs 1
    setprop sys.usb.ffs.aio_compat 1
    setprop sys.usb.controller musb-hdrc
    setprop ro.boot.usbcontroller musb-hdrc
    
    # Pembuatan Direktori Inti
    mkdir /tmp 0777 root root
    mkdir /data 0771 system system
    restorecon /tmp
    
    # Ekspor Jalur Pustaka Dinamis
    export LD_LIBRARY_PATH /system/lib64:/vendor/lib64:/system/lib:/vendor/lib:/sbin

on fs
    write /sys/class/udc/musb-hdrc/device/cmode 1
    
    # 1. Hubungkan dan Pasang Partisi Vendor di Awal Booting
    wait /dev/block/by-name/vendor
    mount ext4 /dev/block/by-name/vendor /vendor ro

    # 2. Jalankan Tiga Layanan IPC Binder Utama untuk Android 10
    start servicemanager
    start hwservicemanager
    start vndservicemanager

on post-fs
    # Tautan Simbolik Preloader (Khas Chipset MediaTek)
    symlink /dev/block/sda /dev/block/mmcblk0boot0
    symlink /dev/block/sdb /dev/block/mmcblk0boot1
    symlink /dev/block/mmcblk0boot0 /dev/block/platform/bootdevice/by-name/preloader_a
    symlink /dev/block/mmcblk0boot1 /dev/block/platform/bootdevice/by-name/preloader_b

on boot
    # Perizinan Input Sentuh (Touchscreen Driver)
    chmod 0666 /dev/input/event0
    chmod 0666 /dev/input/event1
    chmod 0666 /dev/input/event2
    chmod 0666 /dev/input/event3
    chmod 0666 /dev/input/event4
    chmod 0666 /dev/input/event5
    chown root root /dev/input/event0
    chown root root /dev/input/event1
    chown root root /dev/input/event2
    chown root root /dev/input/event3
    chown root root /dev/input/event4
    chown root root /dev/input/event5

    # START DRM SERVICES (Fixes the frozen splash screen!)
    start allocator-2-0
    start hwcomposer-2-1

on post-fs-data
    # Nyalakan Logging Sistem Pemulihan
    start logd

# ============================================================
# DEFINISI CORE SERVICES ANDROID 10 & TWRP
# ============================================================

service servicemanager /system/bin/servicemanager
    class core
    user root
    group root readproc
    disabled
    seclabel u:r:recovery:s0

service logd /system/bin/logd
    class core
    user logd
    group logd system package_info readproc
    capabilities SYSLOG AUDIT_CONTROL
    priority 10
    writepid /dev/cpuset/system-background/tasks
    seclabel u:r:logd:s0

service logcat /system/bin/logcat -b all -v threadtime -f /tmp/logcat.txt
    class boot
    user root
    group root
    disabled
    seclabel u:r:recovery:s0

# ADDED: vold service definition! 
# FBE Decryption REQUIRES vold. The "start vold" command in microtrust.rc depends on this definition.
service vold /system/bin/vold
    class core
    user root
    group root mount reserved_disk
    disabled
    seclabel u:r:vold:s0

# ============================================================
# DRM GRAPHICS SERVICES
# ============================================================

service allocator-2-0 /vendor/bin/hw/android.hardware.graphics.allocator@2.0-service
    class main
    user system
    group graphics drmrpc
    disabled

service hwcomposer-2-1 /vendor/bin/hw/android.hardware.graphics.composer@2.1-service
    class main
    user system
    group graphics drmrpc
    disabled

import /init.recovery.microtrust.rc

on init
    # Pembuatan Direktori Inti & Temp
    mkdir /tmp 0777 root root
    restorecon /tmp

    # CRITICAL FIX UNIFIED: Struktur Cgroups & Cpuset murni
    mkdir /dev/cpuset 0750 root system
    mount cgroup none /dev/cpuset cpuset
    mkdir /dev/cpuset/foreground 0750 root system
    mkdir /dev/cpuset/background 0750 root system
    mkdir /dev/cpuset/system-background 0750 root system
    mkdir /dev/cpuset/top-app 0750 root system
    write /dev/cpuset/foreground/tasks 1
    write /dev/cpuset/background/tasks 1
    write /dev/cpuset/system-background/tasks 1

    mkdir /dev/cg2_bpf 0750 root system
    mount cgroup2 none /dev/cg2_bpf nodev noexec nosuid

    # USB Configurationfs
    setprop sys.usb.configfs 1
    setprop sys.usb.ffs.aio_compat 1
    setprop sys.usb.controller musb-hdrc
    setprop ro.boot.usbcontroller musb-hdrc
    
    # Ekspor Jalur Pustaka Dinamis (Wajib Menyertakan /sbin)
    export LD_LIBRARY_PATH /system/lib64:/vendor/lib64:/system/lib:/vendor/lib:/sbin

on fs
    write /sys/class/udc/musb-hdrc/device/cmode 1

    # Jalankan binder dasar serentak
    start servicemanager
    start hwservicemanager

on post-fs
    # Tautan Simbolik Preloader (Khas Chipset MediaTek MT6765)
    symlink /dev/block/sda /dev/block/mmcblk0boot0
    symlink /dev/block/sdb /dev/block/mmcblk0boot1
    symlink /dev/block/mmcblk0boot0 /dev/block/platform/bootdevice/by-name/preloader_a
    symlink /dev/block/mmcblk0boot1 /dev/block/platform/bootdevice/by-name/preloader_b
    chmod 0755 /sbin/foxstart.sh

on boot
    # Perizinan Input Sentuh (Touchscreen Driver)
    chmod 0666 /dev/input/event0
    chmod 0666 /dev/input/event1
    chmod 0666 /dev/input/event2
    chmod 0666 /dev/input/event3
    chmod 0666 /dev/input/event4
    chmod 0666 /dev/input/event5

on post-fs-data
    start logd

# MATRIKS STRATEGI DAN RANTAI PEMICU DINAMIS

# Jalankan vold utama begitu TEE Microtrust active
on property:init.svc.teei_daemon=running
    start vold

# SKENARIO A: JALUR ANDROID 10 (ROM Bawaan XOS - SDK 29)
on property:init.svc.vendor.keymaster-4-0-beanpod=running && property:ro.build.version.sdk=29
    start keystore
    start gatekeeperd

# SKENARIO B: JALUR ANDROID 11 (SDK 30)
on property:init.svc.vendor.keymaster-4-0-beanpod=running && property:ro.build.version.sdk=30
    start wait_for_keymaster

on property:init.svc.wait_for_keymaster=stopped && property:ro.build.version.sdk=30
    start keystore
    start gatekeeperd

# SKENARIO C: JALUR ANDROID 12 S/D 14 (Custom ROM - SDK 31 ke atas)
on property:init.svc.vendor.keymaster-4-0-beanpod=running && property:ro.build.version.sdk=31
    start vndservicemanager
    start wait_for_keymaster

on property:init.svc.vendor.keymaster-4-0-beanpod=running && property:ro.build.version.sdk=32
    start vndservicemanager
    start wait_for_keymaster

on property:init.svc.vendor.keymaster-4-0-beanpod=running && property:ro.build.version.sdk=33
    start vndservicemanager
    start wait_for_keymaster

on property:init.svc.vendor.keymaster-4-0-beanpod=running && property:ro.build.version.sdk=34
    start vndservicemanager
    start wait_for_keymaster

# Eksekusi Keystore2 setelah satpam keymaster selesai (Khusus A12 ke atas)
on property:init.svc.wait_for_keymaster=stopped && property:ro.build.version.sdk=31
    start keystore2
    start gatekeeperd

on property:init.svc.wait_for_keymaster=stopped && property:ro.build.version.sdk=32
    start keystore2
    start gatekeeperd

on property:init.svc.wait_for_keymaster=stopped && property:ro.build.version.sdk=33
    start keystore2
    start gatekeeperd

on property:init.svc.wait_for_keymaster=stopped && property:ro.build.version.sdk=34
    start keystore2
    start gatekeeperd

# RECOVERY OPTIMIZED CORE SERVICES DEFINITION #

service servicemanager /system/bin/servicemanager
    class core
    user root
    group root readproc
    disabled
    seclabel u:r:recovery:s0

service hwservicemanager /system/bin/hwservicemanager
    class siginallog
    user 1000
    group 1000 readproc
    critical
    onrestart setprop hwservicemanager.ready false
    writepid /dev/cpuset/system-background/tasks
    shutdown critical
    disabled
    seclabel u:r:recovery:s0

service vndservicemanager /system/bin/vndservicemanager /dev/vndbinder
    class core
    user 1000
    group 1000 readproc
    writepid /dev/cpuset/system-background/tasks
    shutdown critical
    disabled
    seclabel u:r:recovery:s0

service logd /system/bin/logd
    class core
    user logd
    group logd system package_info readproc
    capabilities SYSLOG AUDIT_CONTROL
    priority 10
    writepid /dev/cpuset/system-background/tasks
    seclabel u:r:logd:s0

service vold /system/bin/vold \
        --blkid_context=u:r:blkid:s0 --blkid_untrusted_context=u:r:blkid_untrusted:s0 \
        --fsck_context=u:r:fsck:s0 --fsck_untrusted_context=u:r:fsck_untrusted:s0
    class core
    ioprio be 2
    writepid /dev/cpuset/foreground/tasks
    shutdown critical
    group root reserved_disk
    disabled
    seclabel u:r:vold:s0

service gatekeeperd /system/bin/gatekeeperd /data/misc/gatekeeper
    class main
    user 1000
    group 1000 drmrpc
    writepid /dev/cpuset/foreground/tasks
    disabled
    seclabel u:r:recovery:s0

# 🔑 LAYANAN WARISAN: Keystore Tradisional Android 10 & 11 (FIXED GROUP GID)
service keystore /system/bin/keystore /data/misc/keystore
    class main
    user keystore
    group keystore system
    writepid /dev/cpuset/foreground/tasks
    disabled
    seclabel u:r:recovery:s0

# 🔑 LAYANAN MODEREN: Keystore2 Rust Android 12 ke atas
service keystore2 /system/bin/keystore2 /data/misc/keystore
    class main
    user 1000
    group 1000 drmrpc readproc log
    writepid /dev/cpuset/foreground/tasks
    disabled
    seclabel u:r:recovery:s0

service wait_for_keymaster /system/bin/wait_for_keymaster
    class main
    user 1000
    group 1000 system
    priority -20
    ioprio rt 0
    disabled
    oneshot
    seclabel u:r:recovery:s0

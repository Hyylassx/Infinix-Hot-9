# ============================================================
# MICROTRUST BEANPOD CRYPTO SERVICES (TWRP)
# ============================================================

service teei_daemon /vendor/bin/teei_daemon -r 020b0000000000000000000000000000 -r 020f0000000000000000000000000000 -r 06090000000000000000000000000000 -r 05120000000000000000000000000000 -r 40188311faf343488db888ad39496f9a -r 07060000000000000000000000007169 -r 9073f03a9618383bb1856eb3f990babd -r 08050000000000000000000000003419 -r 5020170115e016302017012521300000 -r 0f5eed3c3b5a47afacca69a84bf0efad -r 07407000000000000000000000000000 -r 05160000000000000000000000000000 -r 91dba524a6e24909acc48abd7163121a -r 08030000000000000000000000000000 -r 85f630e0f0964c5fa2cc268ce04e3da3 -r 98fb95bcb4bf42d26473eae48690d7ea -r 7b66512021214487ba710a51d7ea78fe -r 09010000000000000000000000000000
    class core
    user root
    group root
    seclabel u:r:recovery:s0

service teei_capi_2_0 /vendor/bin/hw/vendor.microtrust.hardware.capi@2.0-service
    class core
    user root
    group root
    setenv LD_LIBRARY_PATH /vendor/lib64:/vendor/lib:/system/lib64:/system/lib:/sbin
    seclabel u:r:recovery:s0

service keymaster-attestation /vendor/bin/hw/vendor.mediatek.hardware.keymaster_attestation@1.1-service
    class core
    user root
    group root
    seclabel u:r:recovery:s0

service keymaster-4-0-beanpod /vendor/bin/hw/android.hardware.keymaster@4.0-service.beanpod
    interface android.hardware.keymaster@4.0::IKeymasterDevice default
    user root
    group root
    setenv LD_LIBRARY_PATH /vendor/lib64:/vendor/lib:/system/lib64:/system/lib:/sbin
    seclabel u:r:recovery:s0

service gatekeeper-1-0 /vendor/bin/hw/android.hardware.gatekeeper@1.0-service
    interface android.hardware.gatekeeper@1.0::IGatekeeper default
    user root
    group root
    setenv LD_LIBRARY_PATH /vendor/lib64:/vendor/lib:/system/lib64:/system/lib:/sbin
    seclabel u:r:recovery:s0

# ============================================
# TEE Device Nodes + KEYMASTER SYMLINK
# ============================================
on fs
    # KEYMASTER SYMLINK - Maps TEEI keymaster to standard path
    symlink /dev/ut_keymaster /dev/keymaster
    symlink /dev/ut_keymaster /dev/keymaster0
    chmod 0660 /dev/keymaster
    chown system drmrpc /dev/keymaster
    
    # TEEI devices
    chmod 0660 /dev/teei_client
    chown system system /dev/teei_client
    chmod 0660 /dev/teei_config
    chown system system /dev/teei_config
    chmod 0666 /dev/tee0
    chown system drmrpc /dev/tee0
    chmod 0660 /dev/tz_vfs
    chown system system /dev/tz_vfs
    chmod 0660 /dev/teei_fp
    chown system /dev/teei_fp
    chown system drmrpc /dev/ut_keymaster
    chmod 0660 /dev/ut_keymaster
    chmod 0660 /dev/rpmb0
    chown system system /dev/rpmb0
    chmod 0660 /dev/emmcrpmb0
    chown system system /dev/emmcrpmb0
    chown system system /dev/utr_tui
    chmod 0660 /dev/utr_tui

# ============================================
# TEE Directory Tree
# ============================================
on boot
    chown system system /sys/bus/platform/devices/utos/dcih_notify_test
    chown system system /sys/bus/platform/devices/utos/dcih_wait_notify_test
    chown system system /sys/bus/platform/devices/utos/load_ut_drv
    chown system system /sys/bus/platform/devices/utos/unload_ut_drv
    chown system system /sys/bus/platform/devices/utos/notify_ree_dci_handler

on post-fs-data
    mkdir /data/vendor/thh 0755 system system
    mkdir /data/vendor/thh/tee_00 0755 system system

# ============================================
# Crypto Stack Startup Chain
# ============================================
on property:init.svc.hwservicemanager=running
    wait /dev/teei_client
    start teei_daemon
    # REMOVED: start vold (not using vold crypto)

on property:init.svc.teei_daemon=running
    setprop crypto.ready 1
    start keymaster-4-0-beanpod
    start gatekeeper-1-0
    start keymaster-attestation

on property:init.svc.keymaster-4-0-beanpod=running
    start teei_capi_2_0

# ============================================
# Cleanup
# ============================================
on property:twrp.decrypt.done=true
    stop gatekeeper-1-0
    stop keymaster-4-0-beanpod# ============================================
# Crypto Stack Startup Chain
# ============================================
on property:init.svc.hwservicemanager=running
    wait /dev/teei_client
    start teei_daemon

on property:init.svc.teei_daemon=running
    setprop crypto.ready 1
    start keymaster-4-0-beanpod
    start gatekeeper-1-0
    start keymaster-attestation

on property:init.svc.keymaster-4-0-beanpod=running
    start teei_capi_2_0
    # ADDED: vold MUST start after keymaster is registered.
    # TWRP's custom vold will talk to keymaster to decrypt FBE.
    start vold

# ============================================
# Cleanup
# ============================================
on property:twrp.decrypt.done=true
    stop gatekeeper-1-0
    stop keymaster-4-0-beanpod
    stop keymaster-attestation
    stop teei_capi_2_0
    stop teei_daemon
    stop vold
    stop keymaster-attestation
    stop teei_capi_2_0
    stop teei_daemon
